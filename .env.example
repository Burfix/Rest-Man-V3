# ============================================================
# Si Cantina Sociale — Concierge Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# Supabase — https://supabase.com
# ------------------------------------------------------------

# Public URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (safe to expose to browser — restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role key — NEVER expose to browser
# Used in server-side code only (API routes, server components)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# Google Places API — live Google reviews on /dashboard/reviews
# https://console.cloud.google.com → APIs & Services → Places API
# ------------------------------------------------------------

# Server-side only key — NEVER expose to browser
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Optional: hard-code after first deploy (check Vercel function logs for
# the line: [GoogleReviews] Discovered Place ID: ChIJ...)
# Avoids a findplacefromtext call on every cold start.
GOOGLE_PLACE_ID=

# ------------------------------------------------------------
# OpenAI — https://platform.openai.com
# ------------------------------------------------------------

OPENAI_API_KEY=sk-your_openai_api_key

# ------------------------------------------------------------
# Oracle MICROS BI — Live POS Integration
# Auth flow: OpenID Connect ROPC — POST /oidc-provider/v1/oauth2/token
# ------------------------------------------------------------

# Feature flag — set to "true" to activate live MICROS data.
# When false (default), the system uses cached/existing data.
# NEVER set this to true until all required vars below are configured.
MICROS_ENABLED=false

# Oracle OIDC provider (IDM) base URL — no trailing slash.
# For Oracle MSAF: https://ors-idm.msaf.oraclerestaurants.com
MICROS_AUTH_SERVER=

# MICROS BI Application Server base URL — no trailing slash.
# For Oracle MSAF: https://simphony-home.msaf.oraclerestaurants.com
MICROS_APP_SERVER=

# Registered OIDC client / app ID (from Oracle IDM app registration).
# For Oracle MSAF this is typically a base64-encoded string.
MICROS_CLIENT_ID=

# OIDC client secret — required for client_credentials grant.
# Oracle MSAF OIDC uses client_secret_post: both client_id and client_secret
# are sent in the POST body (not as Authorization: Basic).
# SERVER-SIDE ONLY — never expose to browser. Store in Vercel env vars.
MICROS_CLIENT_SECRET=

# Oracle org / tenant identifier (e.g. "SCS").
# Used as x-app-key fallback and in scopes where required by your tenant.
MICROS_ORG_IDENTIFIER=

# BI API account name — Oracle API account created specifically for API access
# in Oracle IDM (e.g. "SCS_THAMSANQA_BIAPI"). Used for password grant + x-app-key.
MICROS_API_ACCOUNT_NAME=

# BI API account password — SERVER-SIDE ONLY, NEVER expose to browser.
# Quote the value if it contains special characters like # or !
# Store this in Vercel environment variables (not in git).
MICROS_API_ACCOUNT_PASSWORD=

# Location reference for the pilot store (passed as locRef in every API call).
# Typically a short integer or store code string from your Simphony config.
MICROS_LOC_REF=

# Optional: override default Oracle BI API endpoint paths.
# Only set these if your Oracle Simphony deployment uses non-standard paths.
# MICROS_PATH_DAILY_TOTALS=/rms/v1/reports/dailyBusinessSummary
# MICROS_PATH_INTERVALS=/rms/v1/reports/salesByInterval
# MICROS_PATH_GUEST_CHECKS=/rms/v1/guestChecks

# Optional: override OIDC token endpoint path.
# Default is the Oracle MSAF OIDC provider path confirmed by discovery:
#   GET /oidc-provider/v1/.well-known/openid-configuration
# Only change if Oracle support confirms a different path for your tenant.
# MICROS_AUTH_TOKEN_PATH=/oidc-provider/v1/oauth2/token

# Optional: OAuth scope for the client_credentials grant (default: "openid").
# MICROS_AUTH_SCOPE=openid

# ------------------------------------------------------------
# WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp
# ------------------------------------------------------------

# Phone Number ID from Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Permanent access token (or system user token for production)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Webhook verify token — choose any random string; set the same
# value in Meta Developer Console > WhatsApp > Webhooks
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
